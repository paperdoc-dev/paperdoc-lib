{
    "name": "paperdoc-dev/paperdoc-lib",
    "description": "A zero-dependency PHP library for generating, parsing and converting documents (PDF, HTML, CSV, DOCX)",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "pdf",
        "html",
        "csv",
        "docx",
        "document",
        "writer",
        "parser",
        "converter"
    ],
    "authors": [
        {
            "name": "Paperdoc",
            "email": "support@paperdoc.dev"
        }
    ],
    "homepage": "https://paperdoc.dev",
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-mbstring": "*",
        "ext-zip": "*",
        "ext-zlib": "*",
        "neuron-core/neuron-ai": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "illuminate/support": "^11.0|^12.0 Required for Laravel integration (ServiceProvider, Facade)"
    },
    "autoload": {
        "psr-4": {
            "Paperdoc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Paperdoc\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Paperdoc\\PaperdocServiceProvider"
            ],
            "aliases": {
                "Paperdoc": "Paperdoc\\Facades\\Paperdoc"
            }
        }
    }
}
